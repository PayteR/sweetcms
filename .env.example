# ─── Database (required) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/sweetcms

# ─── Auth (required) ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long

# ─── Application (required) ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=SweetCMS
NODE_ENV=development
PORT=3000

# ─── Server ──────────────────────────────────────────────────────────────────
# SERVER_ROLE: all | frontend | api | worker
SERVER_ROLE=all

# ─── Redis (optional — enables BullMQ email queue) ──────────────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# ─── Email / SMTP (optional) ────────────────────────────────────────────────
# Without SMTP config, emails are logged to console in development
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# FROM_EMAIL=noreply@example.com

# ─── Social Login (optional) ────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# ─── Storage ────────────────────────────────────────────────────────────────
# filesystem (default) or s3
STORAGE_BACKEND=filesystem

# S3-compatible storage (required when STORAGE_BACKEND=s3)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=us-east-1
# S3_BUCKET=sweetcms-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# NEXT_PUBLIC_CDN_URL=
